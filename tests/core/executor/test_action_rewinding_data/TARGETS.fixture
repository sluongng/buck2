load(
    ":defs.bzl",
    "consumer",
    "consumer_two",
    "producer",
    "tree_consumer",
    "tree_producer",
)

producer(
    name = "producer",
)

producer(
    name = "producer_first",
    content = "first generated input for action rewind\n",
)

producer(
    name = "producer_second",
    content = "second generated input for action rewind\n",
)

consumer(
    name = "consumer",
    dep = ":producer",
)

consumer_two(
    name = "consumer_two",
    first = ":producer_first",
    second = ":producer_second",
)

producer(
    name = "top_level_output",
    content = "top-level generated output for action rewind\n",
)

tree_producer(
    name = "tree_producer",
)

tree_consumer(
    name = "tree_consumer",
    dep = ":tree_producer",
)
